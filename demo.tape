# peasytext-rb — Text case, slugify, word count (Ruby)
# Theme: Gruvbox
# Generated for AgentGIF demo collection

Output demo.gif
Set Shell "zsh"
Set Theme "GruvboxDark"
Set Width 800
Set Height 500
Set FontSize 14
Set Padding 20
Set TypingSpeed 50ms

# Show package info
Type "# peasytext-rb — Text case, slugify, word count for Ruby"
Enter
Type "# peasytext.com"
Enter
Sleep 500ms

# Run the demo
Type "ruby -I lib examples/demo.rb"
Enter
Sleep 5s
